# =============================================================================
# Hotel Search — Environment Variables
# Copy to .env.local — never commit secrets.
# =============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser calls our Next.js BFF (not SearchAPI directly)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# SearchAPI.io key (SERVER ONLY) — used exactly like the PDF sample's api_key
API_KEY=your_searchapi_key_here

# Optional alias
# SEARCH_API_KEY=your_searchapi_key_here

API_TIMEOUT_MS=60000
